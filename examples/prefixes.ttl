prefix sh: <http://www.w3.org/ns/shacl#>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix up: <http://purl.uniprot.org/core/>
prefix faldo: <http://biohackathon.org/resource/faldo#>
_:sparql_examples_prefixes
  a owl:Ontology ;
  rdfs:comment """This is a collection of SPARQL queries that are examples for use on different websites.""" ;
  owl:imports sh: .

_:sparql_examples_prefixes sh:declare _:prefix_rdf .
_:prefix_rdf
  sh:prefix "rdf" ;
  sh:namespace "http://www.w3.org/1999/02/22-rdf-syntax-ns#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_rdfs .
_:prefix_rdfs
  sh:prefix "rdfs" ;
  sh:namespace "http://www.w3.org/2000/01/rdf-schema#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_skos .
_:prefix_skos
  sh:prefix "skos" ;
  sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_owl .
_:prefix_owl
  sh:prefix "owl" ;
  sh:namespace "http://www.w3.org/2002/07/owl#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_sio .
_:prefix_sio
  sh:prefix "sio" ;
  sh:namespace "http://semanticscience.org/resource/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_bao .
_:prefix_bao
  sh:prefix "bao" ;
  sh:namespace "http://www.bioassayontology.org/bao#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_vocab .
_:prefix_vocab
  sh:prefix "vocab" ;
  sh:namespace "http://rdf.ncbi.nlm.nih.gov/pubchem/vocabulary#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_gene .
_:prefix_gene
  sh:prefix "gene" ;
  sh:namespace "http://rdf.ncbi.nlm.nih.gov/pubchem/gene/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_compound .
_:prefix_compound
  sh:prefix "compound" ;
  sh:namespace "http://rdf.ncbi.nlm.nih.gov/pubchem/compound/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare   _:prefix_obo .
_:prefix_obo
  sh:prefix "obo" ;
  sh:namespace "http://purl.obolibrary.org/obo/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_pubmed .
_:prefix_pubmed
  sh:prefix "pubmed" ;
  sh:namespace "http://rdf.ncbi.nlm.nih.gov/pubmed/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_mesh .
_:prefix_mesh
  sh:prefix "mesh" ;
  sh:namespace "http://id.nlm.nih.gov/mesh/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_sh .
_:prefix_sh
  sh:prefix "sh" ;
  sh:namespace "http://www.w3.org/ns/shacl#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_dc .
_:prefix_dc
  sh:prefix "dc" ;
  sh:namespace "http://purl.org/dc/terms/"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_xsd .
_:prefix_xsd
  sh:prefix "xsd" ;
  sh:namespace "http://www.w3.org/2001/XMLSchema#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_faldo .
_:prefix_faldo
  sh:prefix "faldo" ;
  sh:namespace "http://biohackathon.org/resource/faldo#"^^xsd:anyURI .

_:sparql_examples_prefixes sh:declare _:prefix_prov .
_:prefix_prov
  sh:prefix "prov" ;
  sh:namespace "http://www.w3.org/ns/prov#"^^xsd:anyURI .
