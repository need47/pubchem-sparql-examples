@prefix ex: <https://pubchem.ncbi.nlm.nih.gov/docs/rdf/.well-known/sparql-examples/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix spex:<https://purl.expasy.org/sparql-examples/ontology#> .

ex:003 a sh:SPARQLExecutable,
        sh:SPARQLSelectExecutable ;
    rdfs:comment "What compounds have a pharmacological role of NSAID as defined by CHEBI and molecular weight less than 200 g/mol?"^^rdf:HTML ;
    sh:prefixes _:sparql_examples_prefixes ;
    sh:select """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX obo: <http://purl.obolibrary.org/obo/>
PREFIX sio: <http://semanticscience.org/resource/>

SELECT DISTINCT ?compound
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/compound>
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/descriptor>
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/ruleset>
WHERE {
  ?compound rdf:type ?chebi .
  ?chebi rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty obo:RO_0000087 ;
    owl:someValuesFrom obo:CHEBI_35475
  ] .
  ?compound sio:SIO_000008 ?MW .
  ?MW rdf:type sio:CHEMINF_000334 .
  ?MW sio:SIO_000300 ?MWValue .
  FILTER (?MWValue < 200)
}""" ;
    schema:keywords "pharmacology", "role", "molecular weight" ;
    schema:target <https://pubchem.ncbi.nlm.nih.gov/docs/rdf/> .
