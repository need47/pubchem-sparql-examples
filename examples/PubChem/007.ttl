@prefix ex: <https://pubchem.ncbi.nlm.nih.gov/docs/rdf/.well-known/sparql-examples/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix spex:<https://purl.expasy.org/sparql-examples/ontology#> .

ex:007 a sh:SPARQLExecutable,
        sh:SPARQLSelectExecutable ;
    rdfs:comment "What protein targets are inhibited by substances with IC50 less than 10 µM and have the same standardized chemical structure (CID3152)?"^^rdf:HTML ;
    sh:prefixes _:sparql_examples_prefixes ;
    sh:select """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX sio: <http://semanticscience.org/resource/>
PREFIX compound: <http://rdf.ncbi.nlm.nih.gov/pubchem/compound/>
PREFIX obo: <http://purl.obolibrary.org/obo/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX bao: <http://www.bioassayontology.org/bao#>

SELECT DISTINCT ?sub ?protein ?title
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/protein>
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/measuregroup>
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/endpoint>
FROM <http://rdf.ncbi.nlm.nih.gov/pubchem/substance>
WHERE {
  ?sub sio:CHEMINF_000477 compound:CID3152 ;
       obo:RO_0000056 ?mg .
  ?mg obo:RO_0000057 ?protein ;
      obo:OBI_0000299 ?ep .
  ?protein rdf:type sio:SIO_010043 ;
           skos:prefLabel ?title .
  ?ep rdf:type bao:BAO_0000190 ;
      obo:IAO_0000136 ?sub ;
      sio:SIO_000300 ?value .
  FILTER (?value < 10)
}""" ;
    schema:keywords "protein", "IC50", "chemical structure" ;
    schema:target <https://pubchem.ncbi.nlm.nih.gov/docs/rdf/> .
