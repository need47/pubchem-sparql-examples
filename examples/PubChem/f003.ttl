@prefix ex: <https://pubchem.ncbi.nlm.nih.gov/docs/rdf/.well-known/sparql-examples/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix spex:<https://purl.expasy.org/sparql-examples/ontology#> .

ex:f003 a sh:SPARQLExecutable, sh:SPARQLSelectExecutable ;
    rdfs:comment "How can I retrieve the WURCS sequence from Glycosmos for the glycan structure (SID 252275760) in PubChem?"^^rdf:HTML ;
    sh:prefixes _:sparql_examples_prefixes ;
    sh:select """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX substance: <http://rdf.ncbi.nlm.nih.gov/pubchem/substance/>
PREFIX glycan: <http://purl.jp/bio/12/glyco/glycan#>

SELECT DISTINCT ?gtcid ?wurcs
WHERE {
  GRAPH <http://rdf.ncbi.nlm.nih.gov/pubchem/substance> {
    substance:SID252275760 rdfs:seeAlso ?glycan .
  }

  SERVICE <https://ts.glycosmos.org/sparql> {
    ?glycan dcterms:identifier ?gtcid ;
            glycan:has_glycosequence ?gs .
    ?gs glycan:in_carbohydrate_format glycan:carbohydrate_format_wurcs ;
        glycan:has_sequence ?wurcs .
  }
}""" ;
  schema:keywords "Glycosmos", "glycan", "wurcs" ;
  schema:target <https://pubchem.ncbi.nlm.nih.gov/docs/rdf/> ;
  spex:federatesWith <https://ts.glycosmos.org/sparql> .
